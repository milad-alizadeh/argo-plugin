---
import PipelineWalkthrough from './PipelineWalkthrough.astro'

interface Props {
  headline: string
  subhead: string
  primaryCta: { text: string; href: string }
  secondaryCta: { text: string; href: string }
}
const { headline, subhead, primaryCta, secondaryCta } = Astro.props
---

<section class="hero">
  <h1 class="hero-headline">{headline}</h1>
  <p class="hero-subhead">{subhead}</p>

  <div class="hero-actions">
    <a class="hero-cta hero-cta-primary" href={primaryCta.href}>
      {primaryCta.text}
    </a>
    <a class="hero-cta hero-cta-secondary" href={secondaryCta.href}>
      {secondaryCta.text}
    </a>
  </div>

  <PipelineWalkthrough />
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    padding: 5rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    max-width: 22ch;
    background: linear-gradient(
      135deg,
      var(--sl-color-white, #f3f4f8) 40%,
      var(--argo-color-accent, #5b7cfa)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .hero-subhead {
    max-width: 48ch;
    font-size: 1.125rem;
    color: var(--sl-color-gray-2, #b8bfd1);
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero-cta {
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .hero-cta-primary {
    background: var(--argo-color-accent, #5b7cfa);
    color: #0b0e17;
  }

  .hero-cta-secondary {
    border: 1px solid var(--argo-color-border-ui, #2a3346);
    color: var(--sl-color-white, #f3f4f8);
  }

</style>
