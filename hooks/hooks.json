{
  "description": "Argo guardrails — block destructive git operations and pipe-to-shell supply-chain attacks before they run.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-git.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-pipe-to-shell.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
