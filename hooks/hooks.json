{
  "description": "Argo guardrails — plugin-side SAFETY hooks (destructive-git, pipe-to-shell, shell-source-write, lockfile, designer-spawn, session context) run verbatim from this directory; every kit GATE (red-proof, trust, design-commit, design-coverage, format-on-write, test-smell, design-guard) is dispatched through hooks/kit-dispatch.mjs — fail-closed (exit 2) when the project declares @argohq/kit but it is missing, allow-with-warning when the project is not argo-initialized so bootstrap (bun install) can proceed.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-designer-spawn.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Monitor",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-git.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-pipe-to-shell.mjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-bash-source-write.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/kit-dispatch.mjs\" bash-pretooluse",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-lockfile-edit.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-context.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/kit-dispatch.mjs\" post-edit-write",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "mcp__plugin_figma_figma__use_figma",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/kit-dispatch.mjs\" design-guard-record",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/kit-dispatch.mjs\" design-guard-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/kit-dispatch.mjs\" design-guard-stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
