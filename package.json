{
  "name": "@argo/plugin-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "Dev/test harness for the argo plugin — the distributable manifest is .claude-plugin/plugin.json; this carries the trust-gate acid test.",
  "scripts": {
    "test": "vitest run",
    "eval": "evalite run eval/card-routing.eval.ts",
    "eval:prompts": "evalite run evals/*.eval.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@argohq/toolkit": "workspace:*",
    "@nizos/probity": "^1.10.0",
    "evalite": "^0.16.0",
    "lefthook": "^2.1.10",
    "vitest": "^3.2.4"
  }
}
