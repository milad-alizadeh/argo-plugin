{
  "name": "@argohq/kit",
  "version": "0.1.1",
  "type": "module",
  "description": "Deterministic half of the argo plugin — hook gates, design-kit comparator, skill-script CLI, reporters. The plugin's skills/agents are the LLM half; this package is everything that must run as real code.",
  "bin": {
    "argo": "bin/argo.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": "./src/index.js",
    "./design-kit": "./src/design-kit/index.js",
    "./design-kit/tier0-rules": "./src/design-kit/tier0-rules.ts",
    "./design-kit/tier0-audit": "./src/design-kit/tier0-audit.js",
    "./design-kit/region-contract": "./src/design-kit/region-contract.js",
    "./design-kit/xml-metadata-adapter": "./src/design-kit/xml-metadata-adapter.js",
    "./design-kit/recipes/external-kit": "./src/design-kit/recipes/external-kit.js",
    "./design-kit/shadcn-tailwind": "./src/recipes/shadcn-tailwind/index.js",
    "./design-kit/shadcn-tailwind/tier0-rules": "./src/recipes/shadcn-tailwind/tier0-rules.js",
    "./design-kit/shadcn-tailwind/tier0-walker": "./src/recipes/shadcn-tailwind/tier0-walker.js",
    "./walkers": "./src/walkers/index.js",
    "./reporters/playwright": "./src/reporters/playwright/index.js"
  },
  "files": [
    "bin",
    "src",
    "!src/**/*.test.js"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tdd-guard": "^1.7.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@playwright/test": "*"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
