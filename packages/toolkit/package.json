{
  "name": "@argohq/toolkit",
  "version": "0.21.0",
  "type": "module",
  "description": "The argo npm package — playbook engine (core/), design + code packs (packs/), Claude adapter (adapter-claude/), and the argo CLI. Single install for host projects; the plugin repo's skills/agents are the LLM half.",
  "bin": {
    "argo": "bin/argo.js"
  },
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./adapter-claude": {
      "types": "./dist/adapter-claude/index.d.ts",
      "default": "./dist/adapter-claude/index.js"
    },
    "./packs/design": {
      "types": "./dist/packs/design/index.d.ts",
      "default": "./dist/packs/design/index.js"
    },
    "./walkers": {
      "types": "./dist/packs/design/walkers/index.d.ts",
      "default": "./dist/packs/design/walkers/index.js"
    },
    "./reporters/playwright": {
      "types": "./dist/packs/code/reporters/playwright/index.d.ts",
      "default": "./dist/packs/code/reporters/playwright/index.js"
    },
    "./design-kit": {
      "types": "./dist/packs/design/design-kit/index.d.ts",
      "default": "./dist/packs/design/design-kit/index.js"
    },
    "./design-kit/shadcn-tailwind": {
      "types": "./dist/packs/design/recipes/shadcn-tailwind/index.d.ts",
      "default": "./dist/packs/design/recipes/shadcn-tailwind/index.js"
    },
    "./design-kit/shadcn-tailwind/*": {
      "types": "./dist/packs/design/recipes/shadcn-tailwind/*.d.ts",
      "default": "./dist/packs/design/recipes/shadcn-tailwind/*.js"
    },
    "./design-kit/*": {
      "types": "./dist/packs/design/design-kit/*.d.ts",
      "default": "./dist/packs/design/design-kit/*.js"
    },
    "./skill-scripts/*": {
      "types": "./dist/packs/design/skill-scripts/*.d.ts",
      "default": "./dist/packs/design/skill-scripts/*.js"
    },
    "./design-kit/design-rules": {
      "types": "./dist/packs/design/design-kit/design-rules.d.ts",
      "default": "./dist/packs/design/design-kit/design-rules.js"
    },
    "./design-kit/shadcn-tailwind/design-rules": {
      "types": "./dist/packs/design/recipes/shadcn-tailwind/design-rules.d.ts",
      "default": "./dist/packs/design/recipes/shadcn-tailwind/design-rules.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "tdd-guard": "^1.7.0",
    "wcag-contrast": "^3.0.0"
  },
  "peerDependencies": {
    "@playwright/test": "*"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
